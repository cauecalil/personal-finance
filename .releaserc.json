{
  "branches": [
    "master"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node .github/scripts/sync-release-version.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "backend/pom.xml",
          "frontend/package.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\\n\\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release-assets/*-windows-portable.zip",
            "label": "Windows portable"
          },
          {
            "path": "release-assets/*-macos-portable.zip",
            "label": "macOS portable"
          },
          {
            "path": "release-assets/*-linux-portable.tar.gz",
            "label": "Linux portable"
          },
          {
            "path": "release-assets/SHA256SUMS.txt",
            "label": "SHA256 checksums"
          }
        ]
      }
    ]
  ]
}